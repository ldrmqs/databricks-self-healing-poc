# Sales Analytics Pipeline - Regional Revenue Report

from pyspark.sql import functions as F

# COMMAND ----------
# Load tables
customers = spark.table("databricks_healer.default.customers")
products = spark.table("databricks_healer.default.products")
orders = spark.table("databricks_healer.default.orders")

print("Tables loaded successfully")

# COMMAND ----------
# Join orders with customers and products
sales_data = orders \
    .join(customers, orders.customer_id == customers.customer_id, "inner") \
    .join(products, orders.product_id == products.product_id, "inner")

# COMMAND ----------
# Calculate total amount per order
sales_with_total = sales_data.withColumn(
    "total_amount",
    F.col("quantity") * F.col("unit_price")
)

# COMMAND ----------
# Aggregate: Revenue by region and category
revenue_report = sales_with_total.groupBy(
    F.col("region"),
    F.col("category")
).agg(
    F.sum("total_amount").alias("total_revenue"),
    F.count("order_id").alias("num_orders"),
    F.avg("total_amount").alias("avg_order_value")
)

# COMMAND ----------
# Show results
print("=== Revenue by Region and Category ===")
revenue_report.orderBy(F.desc("total_revenue")).show()

print("Pipeline completed successfully!")